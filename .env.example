# Copy to .env and fill in. Required values are marked (required).

# === Auth ===
SANDBOX_API_KEY=
SANDBOX_WEBHOOK_SECRET=

# Cloudflare Access (verify Cf-Access-Jwt-Assertion header). OPTIONAL — only
# required if you front the API with Cloudflare Access (Zero Trust). Leave
# blank to skip CF Access verification entirely; X-API-Key alone is enough.
# Find in: Cloudflare Zero Trust dashboard → Access → Applications → your app → Application ID (AUD)
SANDBOX_CF_ACCESS_AUD=
# e.g. https://myteam.cloudflareaccess.com/cdn-cgi/access/certs
SANDBOX_CF_ACCESS_CERTS_URL=

# Fernet key for credential encryption at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SANDBOX_FERNET_KEY=

# === Storage / paths ===
SANDBOX_STATE_DB=/var/lib/sandboxes/state.db
SANDBOX_COMPOSE_DIR=/var/lib/sandboxes/composes
SANDBOX_TLS_DIR=/var/lib/sandboxes/tls
SANDBOX_LOG_DIR=/var/log/sandboxes

# === Network ===
SANDBOX_PUBLIC_HOST=api-testdb.abc.co.zm
SANDBOX_MYSQL_HOST=
SANDBOX_PORT_RANGE_START=33060
SANDBOX_PORT_RANGE_END=33999

# Local IP the SSH forward listener binds to and `mysqldump --host=` connects
# to. Default 127.0.0.1 (loopback only). Set to a specific local IP
# (e.g. 10.0.0.5) if your API host has multiple NICs and you want the tunnel
# reachable on that interface only.
SANDBOX_TUNNEL_BIND_HOST=127.0.0.1

# Where the repo is checked out on this host. systemd unit will run with this
# as WorkingDirectory. Defaults to /opt/sqldb-sandbox-setup — adjust if you
# install elsewhere.
SANDBOX_WORKING_DIR=/opt/sqldb-sandbox-setup

# === Prod access (SSH tunnel + dump-only MySQL user) ===
# SSH login target (the bastion). Independent from where MySQL actually runs.
PROD_SSH_HOST=
PROD_SSH_USER=sandbox
PROD_SSH_KEY=/home/sandbox/.ssh/sandbox_prod_ed25519
PROD_SSH_PORT=22
# Remote MySQL the SSH tunnel forwards to (as seen from the bastion).
PROD_MYSQL_HOST=
PROD_MYSQL_PORT=3306
PROD_MYSQL_USER=
PROD_MYSQL_PASSWORD=

# === Container / TTL ===
SANDBOX_MYSQL_IMAGE=mysql:8.4
SANDBOX_TTL_MIN_SECONDS=14400
SANDBOX_TTL_DEFAULT_SECONDS=21600
SANDBOX_TTL_MAX_SECONDS=28800
SANDBOX_TTL_RESET_ADD_SECONDS=7200
SANDBOX_REAPER_INTERVAL_SECONDS=30

# Set to "1" to skip CF Access / API key / webhook HMAC checks.
# Use ONLY for local testing. Never set this in production.
SANDBOX_TEST_MODE=0

# === Nginx front-end (deploy/nginx/sqldb-sandbox.conf) ===
# SSL cert + key. With Cloudflare "DNS only" + nginx-on-host, the easiest path
# is a Let's Encrypt cert via certbot; alternatively pin a Cloudflare Origin CA
# cert (10y) into both here.
SANDBOX_NGINX_SSL_CERT=/etc/letsencrypt/live/api-testdb.abc.co.zm/fullchain.pem
SANDBOX_NGINX_SSL_KEY=/etc/letsencrypt/live/api-testdb.abc.co.zm/privkey.pem
# Override the API hostname only if it differs from SANDBOX_PUBLIC_HOST.
# SANDBOX_NGINX_SERVER_NAME=api-testdb.abc.co.zm
# Override uvicorn upstream if you change run.sh's port.
# SANDBOX_NGINX_UPSTREAM=127.0.0.1:8080