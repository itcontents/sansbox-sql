services:
  mysql:
    container_name: {{ container_name }}
    image: {{ mysql_image }}
    user: "999:999"
    restart: "no"
    command:
      - --ssl-ca=/etc/mysql/tls/ca.pem
      - --ssl-cert=/etc/mysql/tls/server-cert.pem
      - --ssl-key=/etc/mysql/tls/server-key.pem
      - --require-secure-transport=ON
      - --local-infile=0
      - --performance-schema=ON
    environment:
      MYSQL_ROOT_PASSWORD: "{{ root_password }}"
      MYSQL_ROOT_HOST: "%"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges
    pids_limit: 256
    cpus: 1.0
    mem_limit: 2g
    ports:
      - "{{ bind_host }}:{{ host_port }}:3306"
    volumes:
      - sandbox-{{ sid }}-data:/var/lib/mysql
      - "{{ log_dir }}:/var/log/mysql"
      - "{{ tls_dir }}:/etc/mysql/tls:ro"
      - "{{ cnf_path }}:/etc/mysql/conf.d/sandbox.cnf:ro"
    healthcheck:
      test:
        - CMD-SHELL
        - mysqladmin ping -h 127.0.0.1 -uroot -p"$$MYSQL_ROOT_PASSWORD" --ssl-mode=REQUIRED --ssl-ca=/etc/mysql/tls/ca.pem
      interval: 5s
      timeout: 5s
      retries: 60
      start_period: 180s

volumes:
  sandbox-{{ sid }}-data: