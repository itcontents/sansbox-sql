[mysqld]
ssl-ca = /etc/mysql/tls/ca.pem
ssl-cert = /etc/mysql/tls/server-cert.pem
ssl-key = /etc/mysql/tls/server-key.pem
require-secure-transport = ON
local-infile = 0
performance-schema = ON
# default-authentication-plugin is a CLI-only option in MySQL 8.x; the
# server refuses it from mysqld.cnf with MY-000067. We start the container
# with `--default-authentication-plugin=caching_sha2_password` instead.
skip-name-resolve
log_error = /var/log/mysql/error.log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2
# Full statement audit for the sandbox: every Connect/Query/Quit lands in
# general.log, which is bind-mounted to /var/log/sandboxes/<ticket>-<date>/<sid>/
# and preserved after nuke + logrotate. Disk use at typical interactive load
# is small; per-query fsync cost is acceptable for a per-DB-scoped dev session.
general_log = 1
general_log_file = /var/log/mysql/general.log
log_output = FILE
max_connections = 50